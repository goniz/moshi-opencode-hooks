{
  "name": "moshi-opencode-hooks",
  "version": "1.0.15",
  "description": "OpenCode plugin for Moshi live activity integration",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/goniz/moshi-opencode-hooks.git"
  },
  "module": "index.ts",
  "type": "module",
  "main": "index.ts",
  "bin": {
    "moshi-opencode-hooks": "src/cli.ts"
  },
  "exports": {
    ".": "./index.ts"
  },
  "scripts": {
    "build": "bun build index.ts --outdir=dist --target=bun --format=esm",
    "typecheck": "bun tsc --noEmit",
    "release": "bash scripts/release.sh"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.2.27"
  }
}
